# Evocode Core (не 8080=chat, не 8081=legacy embed)
PORT=8083
OPENROUTER_API_KEY=
EVOCODE_MODE=strict

# attach = только HTTP к уже запущенному llama (рекомендуется)
# spawn = вызвать startScript / binary
EVOCODE_LLAMA_MODE=attach
EVOCODE_CHAT_PROFILE=coder
EVOCODE_EMBED_PROFILE=embed-nomic

# Перекрытия (опционально; иначе config/profiles.json)
LLAMA_HOST=http://127.0.0.1
LLAMA_PORT=8080
LLAMA_BINARY=/home/bezoom/ik_llama.cpp/build/bin/llama-server
LLAMA_MODEL=/home/bezoom/llama.cpp/models/Qwopus3.6-27B-Coder-MTP-IQ4_XS.gguf
LLAMA_FIM_PORT=8082
LLAMA_FIM_MODEL=/home/bezoom/storage/Projects/Neurocontrol/models/Qwen1.5B-Instruct-Upscale-3.5B.Q4_K_M.gguf
EVOCODE_CORE_URL=http://127.0.0.1:8083/v1

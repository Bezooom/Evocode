# Evocode Core (not 8080=chat, not 8081=legacy embed)
PORT=8083
OPENROUTER_API_KEY=
EVOCODE_MODE=strict

# attach = HTTP only to already running llama (recommended)
# spawn = startScript / binary from config/profiles.json
EVOCODE_LLAMA_MODE=attach
EVOCODE_CHAT_PROFILE=coder
EVOCODE_EMBED_PROFILE=embed-nomic
EVOCODE_FIM_PROFILE=fim-small

# Optional overrides (otherwise config/profiles.json)
LLAMA_HOST=http://127.0.0.1
LLAMA_PORT=8080
# LLAMA_BINARY=$HOME/ik_llama.cpp/build/bin/llama-server
# LLAMA_MODEL=$HOME/llama.cpp/models/your-chat.Q4_K_M.gguf
LLAMA_FIM_PORT=8082
# LLAMA_FIM_MODEL=$HOME/models/your-fim.Q4_K_M.gguf
# LLAMA_FIM_ENABLED=true

EVOCODE_CORE_URL=http://127.0.0.1:8083/v1

# Optional: non-localhost clients need a Bearer token
# EVOCODE_AUTH_TOKEN=

# Skills router
# EVOCODE_SKILL_ROUTER=v2
# EVOCODE_SKILLS_EMBED=true
# EVOCODE_SKILLS_ALLOW_LAB=false

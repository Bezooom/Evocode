test-results/

# Temporary
tmp/
temp/

# Local runtime data (RAG DB, models — not source)
.evocode/
*.db
*.db-journal
models/
*.gguf

# Vendor trees (bootstrap clones — not committed whole)
packages/ide/vscodium/
packages/ide/code-oss/
packages/agent-extension/upstream/
packages/agent-extension/extension/
vendor/

# F2.3 staged extension payload (regenerate: npm run ide:preinstall-agent)
packages/ide/preinstall/evocode-agent/
packages/ide/preinstall/manifest.json
packages/ide/preinstall/install-record.json
packages/ide/preinstall/settings.default.json
packages/ide/preinstall/product-extensions.fragment.json

# Skills: user overrides & backups stay local
skills/user/**
!skills/user/.gitkeep
skills/.backup/
skills/.archive/
skills/system/subsidy-opk-1780/

# Python cruft under skills
**/__pycache__/
*.py[cod]
*.egg-info/

# Optional large assets
*.AppImage
*.deb
*.dmg
*.exe

# Portable IDE tree (~600MB+, regenerate: npm run ide:package-portable)
packages/ide/dist/

# Local IDE userdata (profile lives in ~/.evocode-ide)
.evocode-ide-userdata/
.evocode-ide/
packages/agent-extension/brand/icons/evocode-imagine-ref.jpg

{
  "$comment": "Local runtime profiles. Paths: $HOME / ${VAR} / ~ — no GGUF copies. See profiles.example.json.",
  "modelsDir": "$HOME/llama.cpp/models",
  "defaults": {
    "chatProfile": "coder",
    "embedProfile": "embed-nomic",
    "fimProfile": "fim-small",
    "corePort": 8083,
    "mode": "attach",
    "autoStartFim": true
  },
  "profiles": {
    "coder": {
      "role": "chat",
      "description": "Default IDE: Ornith 35B Coder + ik_llama (fit, KV q4). Recommended for agent.",
      "binary": "$HOME/ik_llama.cpp/build/bin/llama-server",
      "model": "$HOME/llama.cpp/models/ornith-1.0-35b-Q4_K.gguf",
      "port": 8080,
      "startScript": "$HOME/start_ik_ai4.sh",
      "args": [
        "--fit", "--fit-margin", "1664",
        "--ctx-size", "131072",
        "--cache-type-k", "q4_0",
        "--cache-type-v", "q4_0",
        "--threads", "4",
        "--batch-size", "2048",
        "--ubatch-size", "256",
        "--parallel", "1",
        "--jinja",
        "--no-warmup",
        "-ngl", "99"
      ]
    },
    "chat-ornith": {
      "role": "chat",
      "description": "ornith 35B Q4_K + ik (start_ik_ai4.sh)",
      "binary": "$HOME/ik_llama.cpp/build/bin/llama-server",
      "model": "$HOME/llama.cpp/models/ornith-1.0-35b-Q4_K.gguf",
      "port": 8080,
      "startScript": "$HOME/start_ik_ai4.sh"
    },
    "chat-agentworld": {
      "role": "chat",
      "description": "AgentWorld 35B + ik (start_ik_ai3.sh)",
      "binary": "$HOME/ik_llama.cpp/build/bin/llama-server",
      "model": "$HOME/llama.cpp/models/Qwen-AgentWorld-35B-A3B-Q4_K_M.gguf",
      "port": 8080,
      "startScript": "$HOME/start_ik_ai3.sh"
    },
    "chat-buun": {
      "role": "chat",
      "description": "buun turbo KV + ornith 35B · ctx 262k. GPU for chat; FIM/embed on CPU (-ngl 0).",
      "binary": "$HOME/buun-llama-cpp/build/bin/llama-server",
      "model": "$HOME/llama.cpp/models/ornith-1.0-35b-Q4_K.gguf",
      "port": 8080,
      "args": [
        "-ngl", "99",
        "--ctx-size", "262144",
        "--cache-type-k", "turbo4",
        "--cache-type-v", "turbo4",
        "-fa", "on",
        "--parallel", "1",
        "-t", "8",
        "--batch-size", "2048",
        "--ubatch-size", "256",
        "--n-predict", "32768",
        "--timeout", "900",
        "--no-warmup",
        "--jinja"
      ]
    },
    "embed-nomic": {
      "role": "embed",
      "description": "nomic embeddings :8084 · CPU (-ngl 0), keeps VRAM free for chat 35B",
      "binary": "$HOME/buun-llama-cpp/build/bin/llama-server",
      "model": "$HOME/llama.cpp/models/nomic-embed-text-v1.5.Q4_K_M.gguf",
      "port": 8084,
      "args": [
        "-ngl", "0",
        "--embedding",
        "-t", "8",
        "-c", "8192",
        "--parallel", "2",
        "--batch-size", "512",
        "--ubatch-size", "512",
        "--host", "127.0.0.1"
      ]
    },
    "fim-small": {
      "role": "fim",
      "description": "FIM / autocomplete · small Qwen-class ~2G · CPU (-ngl 0)",
      "binary": "$HOME/ik_llama.cpp/build/bin/llama-server",
      "model": "$HOME/models/fim-small.Q4_K_M.gguf",
      "port": 8082,
      "args": [
        "-ngl", "0",
        "-c", "8192",
        "--parallel", "1",
        "-t", "8",
        "--batch-size", "512",
        "--ubatch-size", "128",
        "--jinja",
        "--no-warmup",
        "--host", "127.0.0.1"
      ]
    }
  },
  "keep": {
    "binaries": [
      "$HOME/buun-llama-cpp",
      "$HOME/ik_llama.cpp",
      "$HOME/llama.cpp/models"
    ],
    "models": [
      "ornith-1.0-35b-Q4_K.gguf",
      "nomic-embed-text-v1.5.Q4_K_M.gguf",
      "Qwen-AgentWorld-35B-A3B-Q4_K_M.gguf",
      "Qwen1.5B-Instruct-Upscale-3.5B.Q4_K_M.gguf"
    ]
  }
}

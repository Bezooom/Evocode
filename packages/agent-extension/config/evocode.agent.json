{
  "$schema": "https://app.kilo.ai/config.json",
  "_comment": "Эвокод agent config template → ~/.config/evocode/agent/evocode.json (OpenAI-compatible Core :8083/v1)",
  "model": "evocode/evocode-auto",
  "small_model": "evocode/evocode-local",
  "enabled_providers": ["evocode"],
  "disabled_providers": ["kilo"],
  "provider": {
    "evocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Эвокод",
      "options": {
        "baseURL": "http://127.0.0.1:8083/v1",
        "apiKey": "evocode-local"
      },
      "models": {
        "evocode-auto": {
          "name": "Auto (router)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "evocode-local": {
          "name": "Local",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "skills": {
    "paths": [
      "~/.config/evocode/skills/system",
      "~/.config/evocode/skills/user"
    ]
  }
}

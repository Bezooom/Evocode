{
  "locale": "ru",
  "window.title": "Эвокод — ${activeEditorShort}${separator}${rootName}",
  "window.commandCenter": false,
  "window.menuBarVisibility": "compact",
  "window.titleBarStyle": "custom",
  "window.density.editorTabHeight": "compact",
  "window.confirmSaveUntitledWorkspace": false,
  "window.openWithoutArgumentsInNewWindow": "on",

  "evocode-agent.new.model.providerID": "evocode",
  "evocode-agent.new.model.modelID": "evocode-auto",
  "evocode-agent.new.language": "Русский",

  "evocode.shell.autoStartCore": true,
  "evocode.shell.autoStartDefaultModel": true,
  "evocode.shell.defaultModelProfile": "coder",
  "evocode.shell.openProductOnStartup": false,
  "evocode.shell.autoFocusAgent": true,

  "workbench.colorTheme": "Default Dark Modern",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.welcomePage.walkthroughs.openOnInstall": false,
  "workbench.banner.enabled": false,
  "workbench.layoutControl.enabled": false,
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": true,
  "workbench.editor.showTabs": "single",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.editor.enablePreview": true,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 6,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.tree.indent": 12,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.reduceMotion": "on",
  "workbench.enableExperiments": false,
  "workbench.settings.enableNaturalLanguageSearch": false,

  "chat.commandCenter.enabled": false,
  "chat.agent.enabled": false,
  "chat.editor.enabled": false,
  "inlineChat.enabled": false,
  "inlineChat.enableV2": false,
  "github.copilot.enable": { "*": false },
  "github.copilot.editor.enableAutoCompletions": false,

  "git.autofetch": false,
  "git.confirmSync": false,
  "github.gitAuthentication": false,
  "github.showAvatar": false,
  "git.openRepositoryInParentFolders": "never",
  "scm.alwaysShowRepositories": false,
  "scm.defaultViewMode": "tree",

  "accounts.sidebar": false,
  "extensions.ignoreRecommendations": true,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "telemetry.telemetryLevel": "off",
  "update.mode": "none",
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.banner": "never",

  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.renderLineHighlight": "gutter",
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Menlo, Monaco, monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 22,
  "editor.padding.top": 16,
  "editor.padding.bottom": 16,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.indentation": false,
  "editor.scrollbar.verticalScrollbarSize": 8,
  "editor.scrollbar.horizontalScrollbarSize": 8,
  "editor.overviewRulerBorder": false,
  "breadcrumbs.enabled": false,
  "explorer.compactFolders": true,
  "explorer.decorations.badges": false,
  "explorer.openEditors.visible": 0,
  "problems.visibility": false,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.tabs.enabled": false,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#050508",
    "titleBar.inactiveBackground": "#050508",
    "titleBar.activeForeground": "#e0e2ed",
    "titleBar.inactiveForeground": "#757a99",
    "titleBar.border": "#050508",
    "activityBar.background": "#050508",
    "activityBar.foreground": "#e0e2ed",
    "activityBar.inactiveForeground": "#5b5f7a",
    "activityBar.activeBorder": "#6b5cf6",
    "activityBar.border": "#050508",
    "sideBar.background": "#07080c",
    "sideBar.foreground": "#e0e2ed",
    "sideBar.border": "#07080c",
    "editor.background": "#0a0b10",
    "editor.foreground": "#e0e2ed",
    "statusBar.background": "#050508",
    "statusBar.foreground": "#757a99",
    "statusBar.border": "#050508",
    "statusBar.noFolderBackground": "#050508",
    "tab.activeBackground": "#0a0b10",
    "tab.inactiveBackground": "#07080c",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveForeground": "#757a99",
    "tab.border": "#07080c",
    "tab.activeBorderTop": "#6b5cf6",
    "editorGroupHeader.tabsBackground": "#07080c",
    "editorGroupHeader.tabsBorder": "#07080c",
    "editorGroup.border": "#07080c",
    "panel.background": "#07080c",
    "panel.border": "#07080c",
    "panelTitle.activeForeground": "#e0e2ed",
    "panelTitle.inactiveForeground": "#5b5f7a",
    "panelTitle.activeBorder": "#6b5cf6",
    "commandCenter.background": "#050508",
    "commandCenter.border": "#050508",
    "list.hoverBackground": "#121422",
    "list.activeSelectionBackground": "#1d1f30",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#151726",
    "list.focusBackground": "#121422",
    "list.hoverForeground": "#ffffff",
    "input.background": "#121422",
    "input.foreground": "#ffffff",
    "input.border": "#21253b",
    "input.placeholderForeground": "#5b5f7a",
    "focusBorder": "#6b5cf6",
    "button.background": "#6b5cf6",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#7f71f8"
  }
}

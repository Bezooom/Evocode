{
  "name": "evocode-shell",
  "displayName": "Эвокод",
  "description": "Нативная оболочка Эвокод: toolbar, модели, настройки IDE.",
  "version": "1.0.0",
  "publisher": "evocode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "icon": "icon.png",
  "contributes": {
    "customEditors": [
      {
        "viewType": "evocode.htmlPreview",
        "displayName": "Эвокод: Предпросмотр документа",
        "selector": [
          {
            "filenamePattern": "*.html"
          },
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "evocode.shell.openProduct",
        "title": "Модели / программа",
        "category": "Эвокод",
        "icon": "$(server-process)"
      },
      {
        "command": "evocode.shell.models",
        "title": "Модели",
        "category": "Эвокод",
        "icon": "$(server-process)"
      },
      {
        "command": "evocode.shell.settings",
        "title": "Настройки",
        "category": "Эвокод",
        "icon": "$(settings-gear)"
      },
      {
        "command": "evocode.shell.openIdeSettings",
        "title": "Параметры IDE (Эвокод)",
        "category": "Эвокод",
        "icon": "$(settings-gear)"
      },
      {
        "command": "evocode.shell.focusAgent",
        "title": "Чат агента",
        "category": "Эвокод",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "evocode.shell.agentManager",
        "title": "Менеджер агентов",
        "category": "Эвокод",
        "icon": "$(organization)"
      },
      {
        "command": "evocode.shell.profile",
        "title": "Профиль",
        "category": "Эвокод",
        "icon": "$(account)"
      },
      {
        "command": "evocode.shell.ensureCore",
        "title": "Проверить Core",
        "category": "Эвокод"
      },
      {
        "command": "evocode.shell.showStatus",
        "title": "Статус",
        "category": "Эвокод"
      },
      {
        "command": "evocode.shell.startDefaultModel",
        "title": "Запустить coder (chat)",
        "category": "Эвокод"
      },
      {
        "command": "evocode.shell.startFimModel",
        "title": "Запустить FIM / autocomplete (лёгкая)",
        "category": "Эвокод"
      },
      {
        "command": "evocode.shell.installDesktop",
        "title": "Ярлык Ubuntu",
        "category": "Эвокод"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "evocode-shell-ActivityBar",
          "title": "Эвокод Настройки",
          "icon": "media/settings.svg"
        }
      ]
    },
    "views": {
      "evocode-shell-ActivityBar": [
        {
          "type": "webview",
          "id": "evocode.shell.settingsView",
          "name": "Настройки Эвокод"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "evocode.shell.openProduct",
          "group": "navigation@90",
          "when": "true"
        },
        {
          "command": "evocode.shell.focusAgent",
          "group": "navigation@91",
          "when": "true"
        }
      ],
      "commandPalette": [
        {
          "command": "evocode.shell.openProduct"
        },
        {
          "command": "evocode.shell.models"
        },
        {
          "command": "evocode.shell.settings"
        },
        {
          "command": "evocode.shell.openIdeSettings"
        },
        {
          "command": "evocode.shell.focusAgent"
        },
        {
          "command": "evocode.shell.agentManager"
        },
        {
          "command": "evocode.shell.profile"
        },
        {
          "command": "evocode.shell.installDesktop"
        },
        {
          "command": "evocode.shell.startDefaultModel"
        },
        {
          "command": "evocode.shell.ensureCore"
        }
      ]
    },
    "keybindings": [
      {
        "command": "evocode.shell.openProduct",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "evocode.shell.openIdeSettings",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,"
      },
      {
        "command": "evocode.shell.openIdeSettings",
        "key": "ctrl+,",
        "mac": "cmd+,"
      },
      {
        "command": "evocode.shell.focusAgent",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "!terminalFocus"
      },
      {
        "command": "evocode.shell.agentManager",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Эвокод",
      "properties": {
        "evocode.shell.autoStartCore": {
          "type": "boolean",
          "default": true,
          "description": "Автозапуск Core :8083"
        },
        "evocode.shell.autoStartDefaultModel": {
          "type": "boolean",
          "default": true,
          "description": "Автозапуск профиля coder (chat 35B), если LLM offline"
        },
        "evocode.shell.autoStartFimModel": {
          "type": "boolean",
          "default": true,
          "description": "Автозапуск лёгкой FIM/autocomplete (fim-small · Neurocontrol ~2G · CPU :8082)"
        },
        "evocode.shell.defaultModelProfile": {
          "type": "string",
          "default": "coder",
          "description": "Профиль chat (profiles.json)"
        },
        "evocode.shell.fimModelProfile": {
          "type": "string",
          "default": "fim-small",
          "description": "Профиль FIM/autocomplete (profiles.json)"
        },
        "evocode.shell.openProductOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Открывать панель моделей при старте"
        },
        "evocode.shell.autoFocusAgent": {
          "type": "boolean",
          "default": true,
          "description": "Открывать чат Эвокод при старте (по умолчанию да)"
        },
        "evocode.shell.corePort": {
          "type": "number",
          "default": 8083
        },
        "evocode.shell.coreRoot": {
          "type": "string",
          "default": ""
        },
        "evocode.shell.showWelcome": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
